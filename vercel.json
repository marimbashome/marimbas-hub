{
  "rewrites": [
    {
      "source": "/blog/:path*",
      "destination": "https://marimbas-blog.vercel.app/blog/:path*"
    }
  ],
  "headers": [
    {
      "source": "/blog/:path*",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "all"
        }
      ]
    }
  ]
}